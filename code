<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mathilde — Communication & Web</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --rose: #FF6B6B;
    --orange: #FF9A5C;
    --pink: #FF4E8A;
    --amber: #FFB347;
    --glass-bg: rgba(255, 255, 255, 0.07);
    --glass-border: rgba(255, 255, 255, 0.14);
    --glass-hover: rgba(255, 255, 255, 0.11);
    --text-primary: #FFFFFF;
    --text-secondary: rgba(255,255,255,0.6);
    --text-muted: rgba(255,255,255,0.35);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: #0a0a0f;
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── Orbes de fond ── */
  .bg-orbs {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.35;
  }
  .orb-1 { width: 600px; height: 600px; background: var(--rose); top: -150px; right: -100px; animation: drift1 18s ease-in-out infinite; }
  .orb-2 { width: 500px; height: 500px; background: var(--orange); bottom: 10%; left: -120px; animation: drift2 22s ease-in-out infinite; }
  .orb-3 { width: 350px; height: 350px; background: var(--pink); top: 40%; left: 40%; animation: drift3 26s ease-in-out infinite; }
  .orb-4 { width: 280px; height: 280px; background: var(--amber); bottom: 5%; right: 10%; animation: drift1 20s ease-in-out infinite reverse; }

  @keyframes drift1 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(40px,-60px) scale(1.08); } }
  @keyframes drift2 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-30px,50px) scale(0.92); } }
  @keyframes drift3 { 0%,100% { transform: translate(0,0) scale(1); } 33% { transform: translate(60px,30px) scale(1.05); } 66% { transform: translate(-40px,-40px) scale(0.95); } }

  /* ── Layout ── */
  .container { position: relative; z-index: 1; max-width: 860px; margin: 0 auto; padding: 0 24px; }

  /* ── Glass card ── */
  .glass {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-radius: 24px;
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .glass:hover { background: var(--glass-hover); border-color: rgba(255,255,255,0.22); }

  /* ── Nav flottante ── */
  nav {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    padding: 10px 28px;
    display: flex;
    align-items: center;
    gap: 32px;
    background: rgba(10,10,15,0.55);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border-radius: 100px;
  }
  nav a { font-size: 13px; font-weight: 500; color: var(--text-secondary); text-decoration: none; letter-spacing: 0.02em; transition: color 0.2s; }
  nav a:hover { color: var(--text-primary); }
  .nav-dot { width: 6px; height: 6px; border-radius: 50%; background: linear-gradient(135deg, var(--rose), var(--orange)); }

  /* ── Section spacing ── */
  section { padding: 120px 0; }
  section:first-of-type { padding-top: 160px; }

  /* ── Hero ── */
  .hero { min-height: 100vh; display: flex; align-items: center; padding-top: 100px; padding-bottom: 80px; }
  .hero-inner { padding: 56px 52px; }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 28px;
  }
  .hero-eyebrow span { width: 28px; height: 1px; background: linear-gradient(90deg, var(--rose), var(--orange)); display: inline-block; }
  .hero-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(44px, 7vw, 80px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .hero-title .gradient-text {
    background: linear-gradient(135deg, var(--rose) 0%, var(--orange) 50%, var(--amber) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc { font-size: 17px; color: var(--text-secondary); line-height: 1.7; max-width: 520px; margin-bottom: 40px; font-weight: 300; }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary {
    padding: 13px 28px;
    border-radius: 100px;
    background: linear-gradient(135deg, var(--rose), var(--orange));
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-ghost {
    padding: 13px 28px;
    border-radius: 100px;
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.4); color: var(--text-primary); transform: translateY(-1px); }

  .hero-stats { display: flex; gap: 40px; margin-top: 48px; padding-top: 40px; border-top: 1px solid var(--glass-border); }
  .stat-num { font-family: 'Syne', sans-serif; font-size: 32px; font-weight: 700; background: linear-gradient(135deg, var(--rose), var(--orange)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .stat-label { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

  /* ── À propos ── */
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .about-main { padding: 40px; grid-column: 1 / -1; }
  .about-tag { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rose); margin-bottom: 16px; }
  .section-title { font-family: 'Syne', sans-serif; font-size: clamp(28px, 4vw, 40px); font-weight: 700; line-height: 1.15; margin-bottom: 16px; }
  .section-body { font-size: 15px; color: var(--text-secondary); line-height: 1.8; font-weight: 300; }
  .about-card { padding: 28px 32px; }
  .about-card-icon { font-size: 24px; margin-bottom: 12px; }
  .about-card-title { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
  .about-card-text { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }

  /* ── Projets ── */
  .projects-grid { display: flex; flex-direction: column; gap: 16px; }
  .project-card { padding: 36px 40px; display: flex; align-items: flex-start; gap: 32px; }
  .project-thumb {
    width: 120px;
    height: 90px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(255,107,107,0.25), rgba(255,154,92,0.15));
    border: 1px solid rgba(255,107,107,0.2);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
  }
  .project-meta { flex: 1; }
  .project-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
  .tag { font-size: 11px; padding: 4px 12px; border-radius: 100px; background: rgba(255,107,107,0.12); border: 1px solid rgba(255,107,107,0.25); color: rgba(255,160,130,0.9); font-weight: 500; }
  .project-title { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; margin-bottom: 8px; }
  .project-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.65; }
  .project-link { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: var(--rose); font-weight: 500; text-decoration: none; margin-top: 14px; transition: gap 0.2s; }
  .project-link:hover { gap: 10px; }

  /* ── Compétences ── */
  .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .skill-card { padding: 24px 28px; }
  .skill-icon { font-size: 20px; margin-bottom: 14px; }
  .skill-name { font-size: 15px; font-weight: 600; margin-bottom: 10px; }
  .skill-pills { display: flex; flex-wrap: wrap; gap: 6px; }
  .skill-pill { font-size: 11px; padding: 3px 10px; border-radius: 100px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: var(--text-secondary); }

  /* ── Contact ── */
  .contact-inner { padding: 56px 52px; text-align: center; }
  .contact-inner .section-title { font-size: clamp(32px, 5vw, 52px); }
  .contact-inner .section-body { max-width: 460px; margin: 0 auto 40px; }
  .contact-links { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }

  /* ── Scroll indicator ── */
  .scroll-line { display: flex; flex-direction: column; align-items: center; gap: 8px; margin-top: 48px; }
  .scroll-line span { font-size: 11px; color: var(--text-muted); letter-spacing: 0.08em; }
  .scroll-line-bar { width: 1px; height: 48px; background: linear-gradient(to bottom, rgba(255,107,107,0.6), transparent); }

  /* ── Footer ── */
  footer { padding: 40px 0; text-align: center; }
  footer p { font-size: 12px; color: var(--text-muted); }

  /* ── Reveal on scroll ── */
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 640px) {
    nav { gap: 20px; padding: 10px 20px; }
    .hero-inner, .about-main, .contact-inner { padding: 36px 28px; }
    .project-card { flex-direction: column; gap: 20px; padding: 28px; }
    .project-thumb { width: 100%; height: 80px; }
    .about-grid { grid-template-columns: 1fr; }
    .hero-stats { gap: 24px; }
  }
</style>
</head>
